import discord
import os
from discord.ext import commands

# 設定
intents = discord.Intents.default()
intents.message_content = True
intents.voice_states = True
bot = commands.Bot(command_prefix="!", intents=intents)

room_owners = {}
room_counter = 1

# ボイスチャンネル作成コマンド
@bot.command()
async def create_vc(ctx):
    global room_counter
    guild = ctx.guild
    
    room_name = f"#{room_counter:03} 部屋"
    room_counter += 1
    
    overwrites = {
        guild.default_role: discord.PermissionOverwrite(connect=True),
        ctx.author: discord.PermissionOverwrite(connect=True, manage_channels=True)
    }
    
    vc = await guild.create_voice_channel(room_name, overwrites=overwrites, user_limit=2)
    room_owners[vc.id] = ctx.author.id
    await ctx.send(f"{room_name} を作成しました。")

# ボイスチャンネルの自動管理（空室になったら削除、人数で名前変更）
@bot.event
async def on_voice_state_update(member, before, after):
    global room_owners
    
    # 退出時の削除・空室チェック
    for vc_id, owner_id in list(room_owners.items()):
        vc = member.guild.get_channel(vc_id)
        if not vc:
            del room_owners[vc_id]
            continue
            
        current_count = len(vc.members)
        if current_count == 0:
            await vc.delete()
            del room_owners[vc_id]
        elif current_count >= vc.user_limit:
            await vc.edit(name=f"[満員] {vc.name.split('] ')[-1]}")
        else:
            await vc.edit(name=f"[空室] {vc.name.split('] ')[-1]}")

@bot.event
async def on_ready():
    print(f'Logged in as {bot.user}')

# Botの起動
bot.run(os.environ['DISCORD_TOKEN'])
